      line-height: 100%;
    }

    a[x-apple-data-detectors],
    .unstyle-auto-detected-links a,
    .aBn {
      color: inherit !important;
      text-decoration: none !important;
      border-bottom: 0 !important;
      cursor: default !important;
    }

    .accent-bar { background: linear-gradient(90deg, #00819e 0%, #005f75 100%); height: 5px; }

    .header-cell { background-color: #111111; padding: 28px 32px 24px; text-align: center; }
    .header-eyebrow { font-size: 13px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: #00819e; margin-bottom: 12px; }

    .hero-label { background-color: #111111; padding: 20px 32px 0; font-size: 13px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #00819e; }
    .hero-title { background-color: #111111; padding: 8px 32px 20px; font-size: 26px; font-weight: 900; color: #ffffff; line-height: 1.2; }

    .hero-thumb-cell {
      background-color: #000000;
      background-size: cover;
      background-position: center center;
      height: 338px;
    }

    .summary-cell { background-color: #ffffff; padding: 32px; }
    .section-label { font-size: 13px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: #00819e; margin-bottom: 8px; }
    .summary-passage { font-size: 28px; font-weight: 900; color: #111111; margin-bottom: 8px; line-height: 1.2; }
    .summary-theme { font-size: 15px; color: #4a5568; line-height: 1.6; margin-bottom: 24px; font-style: italic; }
    .scripture-link { display: inline-block; font-size: 13px; font-weight: 700; color: #00819e !important; letter-spacing: 0.5px; border-bottom: 2px solid #00819e; padding-bottom: 1px; margin-bottom: 24px; text-decoration: none !important; }
    .key-points-header { font-size: 13px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #718096; margin-bottom: 12px; }
    .key-point-row { margin-bottom: 12px; }
    .key-point-number { display: inline-block; width: 28px; height: 28px; background-color: #00819e; color: #ffffff; font-size: 13px; font-weight: 900; text-align: center; line-height: 28px; border-radius: 50%; margin-right: 10px; vertical-align: middle; }
    .key-point-text { font-size: 15px; font-weight: 700; color: #1a202c; vertical-align: middle; }
    .divider { border: none; border-top: 1px solid #e2e8f0; margin: 0 0 20px 0; }

    .resources-cell { background-color: #f7f8fa; padding: 28px 32px; }
    .resource-img { border-radius: 6px; border: 1px solid #e2e8f0; width: 100%; display: block; }
    .resource-link {
      display: block;
      font-size: 15px;
      font-weight: 700;
      color: #00819e !important;
      background-color: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 6px;
      padding: 14px 16px;
      text-decoration: none !important;
      line-height: 1.4;
    }

    .action-cell { background-color: #f7f8fa; padding: 28px 32px; }
    .action-btn { font-size: 14px; font-weight: 700; letter-spacing: 0.5px; padding: 16px 24px; border-radius: 4px; text-decoration: none !important; text-align: center; display: block; }
    .action-btn-primary { background-color: #00819e; color: #ffffff !important; }
    .action-btn-secondary { background-color: #111111; color: #ffffff !important; }

    .highlight-cell { background-color: #111111; padding: 0 0 28px 0; text-align: center; }
    .highlight-thumb-link { display: block; line-height: 0; font-size: 0; }
    .highlight-thumb { width: 100%; max-width: 600px; height: auto; display: block; border-radius: 0; }
    .highlight-inner { padding: 24px 32px 0; }
    .highlight-label { font-size: 13px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: #00819e; margin-bottom: 8px; }
    .highlight-heading { font-size: 24px; font-weight: 900; color: #ffffff; margin-bottom: 20px; }

    .social-col { padding: 0; vertical-align: top; }
    .social-spacer { width: 8px; }
    .social-btn {
      display: block;
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0.5px;
      padding: 14px 20px;
      border-radius: 4px;
      text-decoration: none !important;
      text-align: center;
      color: #ffffff !important;
    }
    .social-btn-youtube   { background-color: #FF0000; }
    .social-btn-facebook  { background-color: #1877F2; }
    .social-btn-instagram { background-color: #E1306C; }

    .links-cell { background-color: #ffffff; padding: 28px 32px; }
    .quick-link-row { border-left: 3px solid #00819e; padding: 10px 0 10px 16px; margin-bottom: 12px; }
    .quick-link-row a { font-size: 15px; font-weight: 700; color: #00819e !important; }
    .quick-link-desc { font-size: 13px; color: #718096; margin-top: 2px; }

    .footer-cell { background-color: #0f0f0f; padding: 28px 32px; text-align: center; }
    .footer-text { font-size: 12px; color: #555555; line-height: 1.6; margin-top: 16px; }

    @media screen and (max-width: 600px) {
      .container { width: 100% !important; max-width: 100% !important; }
      .outer-padding { padding: 0 !important; }
      .hero-thumb-cell { height: 200px !important; background-size: cover !important; }
      .hero-link { height: 200px !important; }
      .hero-inner-table { height: 200px !important; min-height: 200px !important; }
      .hero-inner-cell { height: 200px !important; }
      .summary-cell, .resources-cell, .links-cell, .footer-cell, .action-cell { padding: 24px 20px !important; }
      .highlight-inner { padding: 20px 20px 0 !important; }
      .hero-label { padding-left: 20px !important; padding-right: 20px !important; }
      .hero-title { font-size: 20px !important; padding: 8px 20px 20px !important; }
      .summary-passage { font-size: 22px !important; }
      .action-col { display: block !important; width: 100% !important; }
      .action-spacer { display: none !important; }
      .action-btn { margin-bottom: 12px !important; }
      .resource-col { display: block !important; width: 100% !important; margin-bottom: 16px; }
      .resource-spacer { display: none !important; }
      .social-col { display: block !important; width: 100% !important; }
      .social-spacer { display: none !important; }
      .social-btn { margin-bottom: 10px !important; }
    }
  </style>
</head>
